# ==============================================================================
# VANTA EPHEMERAL CHAT - ROOT ENVIRONMENT VARIABLES CONFIGURATION
# ==============================================================================
# Copy this file to root level .env for reference, or configure env variables
# in individual frontend/ and server/ folders as detailed below.

# --- SERVER ENVIRONMENT VARIABLES ---
# Port number for the Express and Socket.IO server to listen on.
PORT=3001

# The domain/URL of the client application allowed to make Socket.IO connections.
# For production: https://vanta.app (or custom domain)
CLIENT_URL=http://localhost:5173

# The domain/URL of the backend server.
SERVER_URL=http://localhost:3001

# Node environment setting: 'development' or 'production'.
NODE_ENV=development


# Note: The public URL (previously VITE_APP_URL) is now dynamically resolved at runtime using window.location.


# The public URL pointing to the backend API.
# For production: https://api.vanta.app
VITE_API_URL=http://localhost:3001

# The public URL pointing to the backend Socket.IO server.
# For production: https://api.vanta.app
VITE_SOCKET_URL=http://localhost:3001
