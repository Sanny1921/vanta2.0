# Vanta Frontend Environment Variables
# Copy to .env for local development or configure in your deployment hosting dashboard

# The public URL of this React application (e.g. for generating absolute invite links)
# For local dev: http://localhost:5173
# For production: https://sanny1921.github.io/vanta
VITE_APP_URL=http://localhost:5173

# The API URL of the backend (if HTTP requests are introduced in the future)
# For local dev: http://localhost:3001
# For production: https://vanta-v2w9.onrender.com
VITE_API_URL=http://localhost:3001

# The URL of the backend Socket.IO server.
# For local dev: http://localhost:3001
# For production: https://vanta-v2w9.onrender.com
VITE_SOCKET_URL=http://localhost:3001
